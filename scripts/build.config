# Build Configuration for Kiro Gateway Go
# This file contains build-time configuration for AWS security features

# Version information
VERSION ?= $(shell git describe --tags --always --dirty 2>/dev/null || echo "dev")
BUILD_TIME ?= $(shell date -u +%Y-%m-%dT%H:%M:%SZ)
COMMIT_HASH ?= $(shell git rev-parse --short HEAD 2>/dev/null || echo "unknown")

# Build flags
BUILD_FLAGS = -ldflags "-X main.Version=$(VERSION) -X main.BuildTime=$(BUILD_TIME) -X main.CommitHash=$(COMMIT_HASH) -s -w"

# CGO is required for SQLite and keychain support
CGO_ENABLED = 1

# Supported platforms for AWS security features
PLATFORMS = \
	linux/amd64 \
	linux/arm64 \
	darwin/amd64 \
	darwin/arm64 \
	windows/amd64

# Docker configuration
DOCKER_REGISTRY ?= ghcr.io
DOCKER_NAMESPACE ?= kiro-gateway
DOCKER_IMAGE ?= $(DOCKER_REGISTRY)/$(DOCKER_NAMESPACE)/kiro-gateway-go

# Security scanning tools
SECURITY_TOOLS = \
	github.com/securecodewarrior/gosec/v2/cmd/gosec@latest \
	honnef.co/go/tools/cmd/staticcheck@latest \
	github.com/golangci/golangci-lint/cmd/golangci-lint@latest

# Test configuration
TEST_TIMEOUT = 10m
TEST_COVERAGE_THRESHOLD = 80

# AWS test credentials (for mocking only)
TEST_AWS_ACCESS_KEY_ID = AKIAIOSFODNN7EXAMPLE
TEST_AWS_SECRET_ACCESS_KEY = wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
TEST_AWS_REGION = us-east-1

# Performance benchmarks thresholds
BENCHMARK_CREDENTIAL_RESOLUTION_MAX = 100ms
BENCHMARK_SIGV4_SIGNING_MAX = 5ms
BENCHMARK_TOKEN_REFRESH_MAX = 200ms

# Security requirements
SECURITY_NO_HARDCODED_SECRETS = true
SECURITY_TLS_MIN_VERSION = 1.2
SECURITY_REQUIRE_CERTIFICATE_VALIDATION = true

# Build optimization
OPTIMIZATION_LEVEL = -O2
STRIP_SYMBOLS = true
COMPRESS_BINARY = true
